# Temporal Analysis
if 'Year' in sales.columns and 'Month' in sales.columns:
    # Sales by year
    yearly_sales = sales.groupby('Year')['Amount'].sum()
    print("\n Sales by year:")
    print(yearly_sales)
    
    # Bar plot by year
    plt.figure(figsize=(10, 5))
    yearly_sales.plot(kind='bar', color='coral')
    plt.title('Total Sales by Year')
    plt.xlabel('Year')
    plt.ylabel('Total Sales ($)')
    plt.xticks(rotation=0)
    plt.tight_layout()
    
    chart_file = os.path.join(charts_path, 'sales_by_year.png')
    plt.savefig(chart_file)
    plt.close()
    print(f" Chart saved: {chart_file}")
    
    # Sales by month (across all years)
    monthly_sales = sales.groupby('Month')['Amount'].mean()
    print("\n Average sales by month:")
    print(monthly_sales)
    
    # Line plot: monthly trend
    plt.figure(figsize=(12, 6))
    monthly_sales.plot(kind='line', marker='o', color='red', linewidth=2)
    plt.title('Average Sales by Month')
    plt.xlabel('Month')
    plt.ylabel('Average Sales ($)')
    plt.xticks(range(1, 13), ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 
                              'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'])
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    
    chart_file = os.path.join(charts_path, 'monthly_trend.png')
    plt.savefig(chart_file)
    plt.close()
    print(f" Chart saved: {chart_file}")
    
    # Sales by quarter
    if 'Quarter' in sales.columns:
        quarterly_sales = sales.groupby('Quarter')['Amount'].mean()
        print("\n Average sales by quarter:")
        print(quarterly_sales)
        
        # Bar plot by quarter
        plt.figure(figsize=(8, 5))
        quarterly_sales.plot(kind='bar', color='lightblue')
        plt.title('Average Sales by Quarter')
        plt.xlabel('Quarter')
        plt.ylabel('Average Sales ($)')
        plt.xticks(rotation=0)
        plt.tight_layout()
        
        chart_file = os.path.join(charts_path, 'quarterly_trend.png')
        plt.savefig(chart_file)
        plt.close()
        print(f" Chart saved: {chart_file}")

"""
Temporal analysis reveals patterns over time:
- Year-over-year growth or decline
- Seasonal patterns (which months perform best)
- Quarterly trends for business planning

Understanding seasonality helps with inventory planning,
marketing campaigns, and resource allocation.
"""

